           minDate: "-5Y",
			maxDate:  0,			
			onClose: function( selectedDate ) {
				$( "#toDate" ).datepicker( "option", "minDate", selectedDate );
			}
		});
 });
 
 $(document).on("input", ".drugExpiryDate, .invoiceDate_", function () {
	    this.value = this.value.replace(/[^0-9\-]/g, '');
	});

 
	function fn_checkBatchNo(num)
	  {
		  var batchNo=num.value;
		  if(batchNo!=null && batchNo!="")
			 {
			 var regAlphaNum=/^[0-9a-zA-Z,.:\/\- ]+$/;
			 if(batchNo.trim().search(regAlphaNum)==-1)
				 {
				 alert("Only alphanumerics and -,.,:,/ are allowed in Batch Number");
				 var bID=num.id;
				 document.getElementById(bID).value="";
				 document.getElementById(bID).focus();
				 return false;
				 }
			 num.value=batchNo.replace(/\s/g, '');;
			 }
	  }
	function resetStatus() {
	    document.getElementById("status").value = "-1";
	    
	}
	function getTodayDate() {
	    var d = new Date();
	    return String(d.getDate()).padStart(2, "0") + "-" +
	           String(d.getMonth() + 1).padStart(2, "0") + "-" +
	           d.getFullYear();
	}

	function resetDrugDropdown() {

	    var drugDropdown = $("#drugListDropdown");

	    if (drugDropdown.hasClass("select2-hidden-accessible")) {
	        drugDropdown.select2('destroy');
	    }

	    drugDropdown.empty();
	    drugDropdown.append("<option value='-1'>Select</option>");

	    drugDropdown.select2({
	        width: '100%',
	        placeholder: "Select",
	        allowClear: true
	    });
	}

	
	function resetPoAndTable() {

	    $("#poDropdown").val("-1");
	    $("#poDropdown").empty().append("<option value='-1'>Select</option>");
	  
	    resetDrugDropdown();

	    $("#tbodyC1").empty();
	    $("#teamDtlsTbl").hide();
	    $("#submitBtn").hide();
	    $("#phcCountDiv").hide();

	    $("#statusHidden").remove();
	}

	function onWcChange() {

	    $("#status").val("-1");

	    resetPoAndTable();
	}

	function onStatusChange() {

	    resetPoAndTable();

	    loadPoList();
	}

	function loadPoList() {
	    var wc = document.getElementById("dispname").value;
	    var status = document.getElementById("status").value;

	    var poDropdown = document.getElementById("poDropdown");
	    poDropdown.innerHTML = '<option value="-1">Select</option>';

	    if (wc === "-1") return;
	    if (status === "-1") return;

	    fetchPODropdown(wc, status);
	}

	function fn_checkDrugQuantity(quantity)
	  {
		  var drugQuantity=quantity.value;
		  if(drugQuantity!=null && drugQuantity!="")
			 {
			 var regAlphaNum=/^[0-9]+$/;
			 if(drugQuantity.trim().search(regAlphaNum)==-1)
				 {
				 alert("Only Numbers are allowed in Quantity.(No Decimal Points)");
				 var qID=quantity.id;
				 document.getElementById(qID).value="";
				 document.getElementById(qID).focus();
				 return false;
				 }
			 quantity.value=drugQuantity.replace(/\s/g, '');;
			 }
		  
	  }
	
	function fetchPODropdown(dispId) { 
		var status = document.getElementById("status").value; 
			if (dispId === "-1") { 
			document.getElementById("poDropdown").innerHTML = '<option value="-1">SELECT PO</option>'; 
			$("#submitBtn").hide();
			$("#tbodyC1").empty();
			return;
			} 
		var xhr = new XMLHttpRequest(); 
		xhr.open("POST", "vendorActionNew.do?actionFlag=getIndentedPoRpt1", true); 
		xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded"); 
		xhr.onreadystatechange = function () {
		    if (xhr.readyState === 4 && xhr.status === 200) {

		        var poDropdown = document.getElementById("poDropdown");
		        poDropdown.innerHTML = '<option value="-1">SELECT PO</option>';

		        try {
		            var response = JSON.parse(xhr.responseText); 
		            if (response.length === 0) {
		                var opt = document.createElement("option");
		                opt.value = "-1";
		                opt.text = "No POs found";
		                poDropdown.appendChild(opt);
		                return;
		            }

		            response.forEach(function (item) {
		                if (item.POID && item.POID !== "-NA-") {
		                    var opt = document.createElement("option");
		                    opt.value = item.POID;
		                    opt.text = item.POID;
		                    poDropdown.appendChild(opt);
		                }
		            });

		        } catch (e) {
		            console.error("JSON parse error:", e);
		            alert("Error loading PO list");
		        }
		    }
		};
 
		xhr.send("dispname=" + encodeURIComponent(dispId) + "&status=" + encodeURIComponent(status)); 
		}
	var minExpiryDate = null;
	function poRpt(poNo, status) {
	    $.ajax({
	        url: 'vendorActionNew.do?actionFlag=poNoOnclick1', 
	        type: 'POST',
	        data: { 'poNo': poNo, 'status': status },
	        success: function(data) {
	            data = data.replace("*", "");
	            var result = JSON.parse(data);

	            var drugDropdown = $("#drugListDropdown");
	            drugDropdown.empty();
	            drugDropdown.append("<option value='ALL'>--SELECT ALL--</option>");

	            for (var i = 0; i < result.length; i++) {
	                var drugOption = "<option value='" + result[i].DRUG_ID + "'>" + result[i].DRUGNAME + "</option>";
	                drugDropdown.append(drugOption);
	            }
	            
	            if (drugDropdown.hasClass("select2-hidden-accessible")) {
	                drugDropdown.select2('destroy');
	            }

	            drugDropdown.select2({
	                width: '100%',
	                placeholder: "Select",
	                allowClear: true
	            });
	            fn_hideImage();
	           // $("#drugListDropdown").show();
	        }
	    });
	}
	
	function handleDrugSelection() {
		var poNo = document.getElementById("poDropdown").value;
		var status = document.getElementById("status").value; 
	    var drugId = $("#drugListDropdown").val();
	    
	    if (drugId === "-1") {
	        return; 
	    }
	    
	    if (drugId === "ALL") {
	        poRpt1(poNo, status, "");
	    } else {
	        poRpt1(poNo, status, drugId);
	    }

	    $("#teamDtlsTbl").hide();
	    $("#submitBtn").hide();
	    $("#tbodyC1").empty();
	    
	    fn_loadImage();
		
	    poRpt1(poNo, status,drugId);
	}
	
	function poRpt1(poNo, status,drugId) {
		GLOBAL_INVOICE_NO = "";
	    $(".invoiceNumber").val("");
	    $("#checkAll").prop("checked", false);
	    
	    //$("#drugListDropdown").select2().val('');
	    
	    $.ajax({
	        url: 'vendorActionNew.do?actionFlag=poNoOnclick1',
	        type: 'POST',
	        data: { 'poNo': poNo, 'status': status,'drugId' : drugId },
	        success: function(data) {
	            data = data.replace("*", "");
	            var result = JSON.parse(data);
	            var content = "";
	            GLOBAL_INVOICE_NO = "";
	            $(".invoiceNumber").val("");
	            $("#checkAll").prop("checked", false);
	            
	        	if (status === 'CD1420') {
	        		$("#quantityHeader").html("Issued Quantity <font color='red'>*</font>");
            	    $("#pendingQtyHeader").show();
            	} else {
            		$("#quantityHeader").html("Quantity <font color='red'>*</font>");
            	    $("#pendingQtyHeader").hide();
            	}

	            if (result.length === 0) {
	            
	                document.getElementById("tbodyC1").innerHTML = 
	                    "<tr><td colspan='11' style='text-align:center;color:red;'>No data available</td></tr>";
	                return;
	            }
	            var today = new Date();
	            var todayStr =
	                String(today.getDate()).padStart(2, "0") + "-" +
	                String(today.getMonth() + 1).padStart(2, "0") + "-" +
	                today.getFullYear();

	            for (var j = 0; j < result.length; j++) {
	            	
	                content += "<tr>";
	                content += "<td><label><input type='checkbox' class='selectableCheckbox'></label></td>";
	                content += "<td style='text-align:center;font-size:13px;'>" + (j + 1) + "</td>";
	                content += "<td style='cursor:pointer;text-align:center'>" + result[j].POID + "</td>";
	                var poDateOnly = "";

	                if (result[j].PODATE) {
	                    var dateStr = result[j].PODATE.toString();
	                    var d;

	                    if (dateStr.match(/^\d{4}-\d{2}-\d{2}/)) {
	                        var parts = dateStr.substring(0, 10).split("-");
	                        poDateOnly = parts[2] + "-" + parts[1] + "-" + parts[0];
	                    } 
	                   
	                    else {
	                        d = new Date(dateStr);
	                        poDateOnly =
	                            String(d.getDate()).padStart(2, "0") + "-" +
	                            String(d.getMonth() + 1).padStart(2, "0") + "-" +
	                            d.getFullYear();
	                    }
	                }


	                content += "<td style='text-align:center'>" + poDateOnly + "</td>";


	                //content += "<td style='text-align:center'>" + result[j].PODATE + "</td>";
	                //content += "<td><input type='hidden' id='dstrbtrId" + j + "' value='" + result[j].DRUG_TYPE_ID + "' /></td>";
	                content += "<td style='text-align:center'>" + result[j].DSTRBTRNAME + "</td>";
	                content += "<input type='hidden' id='poId1_" + j + "' value='" + result[j].PO_ID + "'>";
					content += "<input type='hidden' id='mnfctrId_" + j + "' value='" + result[j].MNFCTR_ID + "'>";
					content += "<input type='hidden' id='mnfctrname_" + j + "' value='" + result[j].MNFCTRNAME + "'>";
					content += "<input type='hidden' id='itemId_" + j + "' value='" + result[j].ITEMID + "'>";
					content += "<input type='hidden' id='dstrbtrId_" + j + "' value='" + result[j].DSTRBTR_ID + "'>";
					content += "<td style='text-align:center;' id='drugType_" + j + "' >" + result[j].DRUGTYPE + "</td>";
	                content += "<td style='display:none;' id='drugCode_" + j + "'>" + result[j].DRUGCODE + "</td>";
	                content += "<td style='display:none;' id='indentId_" + j + "'>" + result[j].INDENT_ID + "</td>";
	                content += "<td style='text-align:center'>" + result[j].DRUGNAME + "</td>";
	                content += "<input type='hidden' id='drugId_" + j + "' value='" + result[j].DRUG_ID + "'>";
	                content += "<input type='hidden' id='drugTypeId_" + j + "' value='" + result[j].DRUG_TYPE_ID + "'>";
	                content += "<input type='hidden' id='submittedQty_" + j + "' value='" +
	                (result[j].ISSUE_QUANT || 0) + "'>";

	              
	                content += "<td style='text-align:center'>" + result[j].LVL + "</td>";
	                
	                content += "<td style='text-align:center'>" + result[j].RCP + "</td>";
	                content += "<td><input type='text' id='drugBatchNo_" + j + "' maxlength='50' class='form-control' style='font-size:13px; text-transform:uppercase;width:11em;' oninput=\"this.value=this.value.replace(/[^a-zA-Z0-9]/g,'').toUpperCase();\"/></td>";
	                /* content += "<td title='Invoice Date'><input type='text' id='invoiceDate_" + j + 
	                "' class='form-control invoiceDate_' style='width:8em;' value='" + todayStr + "'/></td>";
	                 */
	                 content += "<td title='Invoice Date'><input type='text' id='invoiceDate_" + j + "' class='form-control invoiceDate_' style='width:8em;'/></td>";

	                /* content += "<td title='Invoice Date'><input type='text' id='invoiceDate_" + j + "' class='form-control invoiceDate_' style='width:8em;'/></td>"; */
	                /* content += "<td><input type='text' id='invoiceNumber_" + j + "' maxlength='10' class='form-control' style='font-size:13px;text-transform:uppercase;width:10em;' oninput=\"this.value=this.value.replace(/[^a-zA-Z0-9]/g,'').toUpperCase();\"/></td>"; */
	               content += "<td><input type='text' id='invoiceNumber_" + j + "' maxlength='50' " +
		           "class='form-control invoiceNumber' style='font-size:13px;text-transform:uppercase;width:10em;' " +
		           "oninput=\"this.value=this.value.replace(/[^a-zA-Z0-9]/g,'').toUpperCase(); updateInvoice(this);\" /></td>";

	                content += "<td title='Expiry Date'><input type='text' id='drugexpiryDate_" + j + "' class='form-control drugExpiryDate' style='width:8em;'/></td>";
	             
