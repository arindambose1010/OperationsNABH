	function calculateInvoiceAmount(index, rcp) {

	    const status = document.getElementById("statusHidden").value;
	    const gst = parseFloat(document.getElementById("gstSlab_" + index).value) || 0;

	    let qty = 0;
	    if (status === 'CD1420') {
	        const pendingQtyEl = document.getElementById("pendingQty_" + index);
	        qty = pendingQtyEl ? parseFloat(pendingQtyEl.value) || 0 : 0;
	    }
	    else {
	        qty = parseFloat(document.getElementById("dispDrugQuantity_" + index).value) || 0;
	    }

	    let baseAmount = rcp * qty;

	    document.getElementById("invoiceAmount_" + index).value = baseAmount.toFixed(2);
	    let gstAmount = 0;
	    let poAmount = baseAmount;
	    

	    if (gst > 0) {
	         gstAmount = (baseAmount * gst) / 100;
	         poAmount = baseAmount + gstAmount;
	        //document.getElementById("poAmount_" + index).value = poAmount.toFixed(2);
	    } 
	    document.getElementById("gstAmount_" + index).value = gstAmount.toFixed(2);
	    
	    document.getElementById("poAmount_" + index).value = poAmount.toFixed(2);
	}

	
	function fn_submit() {
		
		/* var status = $("#statusHidden").val(); 

	    if (status === 'CD1420') {
	        alert("Let store enter received quantity then vendor can submit remaining quantity");
	        return;
	    } */
		
	    var rows = $("#tbodyC1 tr");
	    if (rows.length === 0) {
	        alert("No records available to submit.");
	        return;
	    }
	    var wc = $("#dispname").val();
	    var vendorPOList = [];
	    var isValid = true;

	    rows.each(function(index) {
	        var row = $(this);
	        var isChecked = row.find("input[type='checkbox']").prop("checked");

	        if (!isChecked) return;

	        var poNo = row.find("td:eq(2)").text().trim();
	        var poDate = row.find("td:eq(3)").text().trim();
	        var mnfctrname = $("#mnfctrname_" + index).val().trim();
	        var indentId = $("#indentId_" + index).text().trim();
	        var drugType = $("#drugType_" + index).text().trim();
	        var drugName = row.find("td:eq(8)").text().trim();
	        var poQty = row.find("td:eq(9)").text().trim();
	        //var poStatus = row.find("td:eq(10)").text().trim();
	        var rcPrice = row.find("td:eq(10)").text().trim();
	        var drugId      = $("#drugId_" + index).val()?.trim();
	        var drugTypeId  = $("#drugTypeId_" + index).val()?.trim();
	        var mnfctrId    = $("#mnfctrId_" + index).val()?.trim();
	        var poId    = $("#poId1_" + index).val()?.trim();
	        var dstrbtrId   = $("#dstrbtrId_" + index).val()?.trim();
	        var batchNo = $("#drugBatchNo_" + index).val()?.trim();
	        var itemId = $("#itemId_" + index).val()?.trim(); 
	        var expiryDate = $("#drugexpiryDate_" + index).val()?.trim();
	        var invoiceNo = $("#invoiceNumber_" + index).val()?.trim();
	        var invoiceDate = $("#invoiceDate_" + index).val()?.trim();
	        var quantity = $("#dispDrugQuantity_" + index).val()?.trim();
	        var submittedQty = parseInt($("#submittedQty_" + index).val() || "0", 10);
	        var pendingQty = 0;
	       
	        if ($("#pendingQty_" + index).length) {
	            pendingQty = parseInt($("#pendingQty_" + index).val() || "0", 10);
	        }
	        
	        var isPartialPO = ($("#pendingQty_" + index).length > 0); 


	        var poQtyNum = parseInt(poQty || "0", 10);
	        if (submittedQty + pendingQty > poQtyNum) {
	            /* alert(
	                "Pending quantity exceeds allowed limit.\n\n" +
	                "PO Qty        : " + poQtyNum + "\n" +
	                "Already Given : " + submittedQty + "\n" +
	                "Allowed Now   : " + (poQtyNum - submittedQty)
	            ); */
	            alert("Pending quantity exceeds allowed limit");
	            isValid = false;
	            return false;
	        }

	        if (Number(quantity) > Number(poQty)) {
	            alert("Dispensed Quantity cannot be greater than PO Quantity in row " + (index + 1));
	            isValid = false;
	            return false;
	        }
	        var gstSlab = $("#gstSlab_" + index).val()?.trim();
	        var invoiceAmount = $("#invoiceAmount_" + index).val()?.trim();
	        
	        $("#hiddenIndentNo").val(indentId);
		    //$("#hiddenStatus").val(poStatus);

	        if (!batchNo || !expiryDate || !invoiceNo || !invoiceDate || !quantity || !gstSlab || !invoiceAmount ||
	        		 (isPartialPO && (!pendingQty && pendingQty !== 0))) {
	            alert("Please fill all required fields for row " + (index + 1));
	            isValid = false;
	            return false; 
	        }
	        var dateRegex = /^\d{2}-\d{2}-\d{4}$/;
	        var expParts = expiryDate.split("-");
	        var enteredExpiryDate = new Date(
	            parseInt(expParts[2], 10),   
	            parseInt(expParts[1], 10) - 1, 
	            parseInt(expParts[0], 10)    
	        );
	        enteredExpiryDate.setHours(0, 0, 0, 0);

	        if (enteredExpiryDate.getTime() < minExpiryDate.getTime()) {
	            alert(
	                "Expiry Date must be at least 90 days from today.\n" +
	                "Please correct Expiry Date in row " + (index + 1)
	            );
	            $("#drugexpiryDate_" + index).val(""); 
	            isValid = false;
	            return false;
	        }
	        if (!dateRegex.test(expiryDate)) {
	            alert("Expiry Date must be in format DD-MM-YYYY (Row " + (index + 1) + ")");
	            $("#drugexpiryDate_" + index).val(""); 
	            isValid = false;
	            return false;
	        }
	        if (!dateRegex.test(invoiceDate)) {
	            alert("Invoice Date must be in format DD-MM-YYYY (Row " + (index + 1) + ")");
	            $("#invoiceDate_" + index).val(""); 
	            isValid = false;
	            return false;
	        }
	    
	        var invParts = invoiceDate.split("-");
	        /* var enteredInvoiceDate = new Date(
	            parseInt(invParts[2], 10),     
	            parseInt(invParts[1], 10) - 1, 
	            parseInt(invParts[0], 10)      
	        );
	        enteredInvoiceDate.setHours(0, 0, 0, 0);

	        var today = new Date();
	        today.setHours(0, 0, 0, 0);

	        if (enteredInvoiceDate.getTime() !== today.getTime()) {
	            alert("Invoice Date must be today's date (Row " + (index + 1) + ")");
	            $("#invoiceDate_" + index).val("").focus(); 
	            isValid = false;
	            return false;
	        } */

	   
	        vendorPOList.push({
	            poNo: poNo,
	            poDate: poDate,
	            mnfctrname:mnfctrname,
	            indentId: indentId,
	            drugName: drugName,
	            drugType: drugType,
	            poQty: poQty,
	           // poStatus: poStatus,
	            rcPrice: rcPrice,
	            batchNo: batchNo,
	            expiryDate: expiryDate,
	            invoiceNo: invoiceNo,
	            itemId: itemId,
	            invoiceDate: invoiceDate,
	           // quantity: quantity,
	            quantity: quantity.toString(),  
    			pendingQty: pendingQty.toString(),
	            gstSlab: gstSlab,
	            invoiceAmount: invoiceAmount,
	            drugId: drugId,
	            drugTypeId: drugTypeId,
	            mnfctrId: mnfctrId,
	            dstrbtrId: dstrbtrId,
	            poId: poId
	        });
	    });

	    if (!isValid) return;
	    if (vendorPOList.length === 0) {
	        alert("Please select at least one record before submitting.");
	        return;
	    }
	    
	    if (!confirm("Do you want to submit ?")) {
	        return; 
	    }

	    var formData = new FormData();
	    formData.append("vendorPOList", JSON.stringify(vendorPOList));
	   // console.log("vendorPOList:::", JSON.stringify(vendorPOList));
	    formData.append("dispname",wc);
	    var selectedItemIds = vendorPOList.map(function(item) {
	        return item.itemId;
	    });
	    $("#hiddenItemIds").val(selectedItemIds.join(","));
	    $("#hiddenPoNo").val(vendorPOList[0].poNo);

	    $.ajax({
	        url: "vendorActionNew.do?actionFlag=saveInventoryDetailsVendor",
	        type: "POST",
	        data: formData,
	       /*   data: {
       			 vendorPOList: JSON.stringify(vendorPOList),
       			 dispname: wc
    			}, */
	        processData: false,
	        contentType: false,       
	       
	        success: function(response) {
	        	/* if (response === "STORE_PENDING") {
	                alert("Please wait. Store has not completed the previous submission.");
	                return;
	            } */
	            alert("Inventory details submitted successfully!");
	            fn_vendorPrintForm();
	            $("#tbodyC1").empty();
	            $("#teamDtlsTbl").hide();
	            $("#phcCountDiv").hide();
	            $("#submitBtn").hide();

	          
	            $("#dispname").val("-1");   
	            $("#status").val("-1");     
	            $("#poDropdown").val("-1"); 
	            resetDrugDropdown();
	            //$("#drugListDropdown").val("-1"); 
	           
	        },
	        error: function(xhr, status, error) {
	            alert("Error while saving data: " + error);
	        }
	    });
	}
	function ajax_download(url, data, input_name) {
		 $('#download_iframe').remove();
	    var $iframe,
	        iframe_doc,
	        iframe_html;

	    if (($iframe = $('#download_iframe')).length === 0) {
	        $iframe = $("<iframe id='download_iframe'" +
	                    " style='display: none' src='about:blank'></iframe>"
	                   ).appendTo("body");
	    }

	    iframe_doc = $iframe[0].contentWindow || $iframe[0].contentDocument;
	    if (iframe_doc.document) {
	        iframe_doc = iframe_doc.document;
	    }

	    iframe_html = "<html><head></head><body><form method='POST' action='" +
	                  url +"'>" +
	                  "<input type=hidden name='" + input_name + "' value='" +
	                  JSON.stringify(data) +"'/></form>" +
	                  "</body></html>";

	    iframe_doc.open();
	    iframe_doc.write(iframe_html);
	    $(iframe_doc).find('form').submit();
	}
	function fn_vendorPrintForm() {
		var wc = $("#dispname").val();
		 var poNo = $("#hiddenPoNo").val();
	    //var poNo = $("#poDropdown").val();
	    var itemIds = $("#hiddenItemIds").val();
	     
	    var url = "vendorActionNew.do?actionFlag=vendorPdf"+"&wc=" + wc + "&poNo=" + poNo+ "&itemIds=" + itemIds;
	   
	    ajax_download(url, {}, 'dataname');
	    
	}



