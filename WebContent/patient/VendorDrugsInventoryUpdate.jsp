			                        "oninput=\"this.value=this.value.replace(/[^0-9]/g,'').replace(/^0+/,''); " +
			                        "calculateInvoiceAmount(" + j + "," + result[j].RCP + "); \" /></td>";
			         }

	                content += "<td style='text-align:center;'>"
	                         + "<select id='gstSlab_" + j + "' class='form-control' style='font-size:13px;width:8em;'"
	                         + " onchange='calculateInvoiceAmount(" + j + "," + result[j].RCP + ");'>"
	                         + "<option value=''>--Select--</option>"
	                         + "<option value='0'>0%</option>"
	                         + "<option value='5'>5%</option>"
	                         + "<option value='12'>12%</option>"
	                         + "<option value='18'>18%</option>"
	                         + "</select></td>";

	                content += "<td><input type='text' id='invoiceAmount_" + j + "' maxlength='10' class='form-control' style='font-size:13px;width:9em;' readonly/></td>";
	                content += "<td><input type='text' id='gstAmount_" + j + "' maxlength='10' class='form-control' style='font-size:13px;width:9em;' readonly/></td>";
	                content += "<td><input type='text' id='poAmount_" + j + "' class='form-control' style='font-size:13px;width:9em;' readonly/></td>";
	                /* content += "<td><input type='file' id='invoiceDocument_" + j + "' accept='.pdf,.jpg,.png' class='form-control' style='font-size:13px;width:20em;'/></td>"; */

	                content += "</tr>";
	            }


	            document.getElementById("tbodyC1").innerHTML = content;
	            
	            var today = new Date();
	            today.setHours(0, 0, 0, 0); 
	            minExpiryDate = new Date(today);
	            minExpiryDate.setDate(minExpiryDate.getDate() + 90);
	            
	            $(".drugExpiryDate").datepicker({
	                defaultDate: "+1w",
	                changeMonth: true,
	                changeYear: true,
	                <%-- showOn: "both",
	                buttonImage: "<%=request.getContextPath()%>/images/calend.gif",
	                buttonImageOnly: true,
	                buttonText: "Calendar", --%>
	                minDate: minExpiryDate,
	                maxDate: "+5Y",
	                dateFormat: "dd-mm-yy",
	                /* onClose: function( selectedDate ) {
		    				$( "#toDate" ).datepicker( "option", "minDate", selectedDate );
		    			} */
	            });
	           

	            
	            $("[id^='invoiceDate_']").datepicker({
	                defaultDate: "+1w",
	                changeMonth: true,
	                changeYear: true,
	             <%--    showOn: "both",
	                buttonImage: "<%=request.getContextPath()%>/images/calend.gif",
	                buttonImageOnly: true,
	                buttonText: "Calendar", --%>  
	                minDate: "-5Y",
	               // minDate: 0,
	                maxDate: 0,
	                dateFormat: "dd-mm-yy"
	            });
	            $('html, body').animate({ scrollTop: 0 }, 500, 'linear');
	            $("#phcDataDiv").hide();
	            $("#phcBackBtn").hide();
	            $("#phcHeading").hide();
	            $("#phcCountDiv").show();     
	            $("#teamDtlsTbl").show();    
	            $("#submitBtn").show();
	            $("#statusHidden").remove();
	            $("body").append("<input type='hidden' id='statusHidden' value='" + status + "'>");
	            fn_hideImage();
	        }
	    });
	}
