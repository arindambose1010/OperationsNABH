              <td class="tbcellBorder"><strong>${drug.caseRegDate}</strong></td>
             <%--  <td>${drug.patientId}</td> --%>
              <td>
                <button class="btn btn-primary btn-sm" onclick="javascript:sendReportRequest('${drug.cardNo}','${drug.swBorders}'); return false;">View Report</button>
              </td>
            </tr>
            <c:set var="serial" value="${serial + 1}" />
        </c:forEach>
