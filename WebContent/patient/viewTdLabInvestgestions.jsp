 <script>
	function sendReportRequest(benId, patId) {
		console.log("sendReportRequest called with:", benId, patId);
		fn_loading();
	    var xhr2 = new XMLHttpRequest();
	    xhr2.open("POST", "https://tdmobile.bhishak.net/api/Reports/GetReport", true);
	    xhr2.setRequestHeader("Content-Type", "application/json");
	    xhr2.onreadystatechange = function () {
	        if (xhr2.readyState === 4) {
	            fn_removeLoading();
	            if (xhr2.status === 200) {
	                try {
	                    if (!xhr2.responseText.trim()) {
	                        alert("Empty response from server");
	                        return;
	                    }
	                    var data = JSON.parse(xhr2.responseText);
	                    if (data.success) {
	                        console.log("Response:: "+data.response);
	                    	openPopup(data.response);
	                    } else {
	                        alert("Report not generated.");
	                    }
	                } catch (error) {
	                    console.error("Error parsing JSON:", error);
	                }
	            } else {
	                console.error("HTTP Error:", xhr2.status);
	            }
	        }
	    };
	    var requestData = JSON.stringify({
	    	 hpPatientId: benId,
	        hpVisitId: patId
	    });
	    console.log("Request Data:", requestData);
	    xhr2.send(requestData);
	}
  function openPopup(reportUrl) {
	    if (reportUrl) {
	        window.open(reportUrl,"Reports",'width=850,height=900,resizable=yes,top=150,left=200,toolbar=no,minimize=no,status=no,memubar=no,location=no,scrollbars=yes');
	    } else {
	        alert("Invalid report URL");
	    }
	}
  </script>
