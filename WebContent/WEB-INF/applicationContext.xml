	<bean id="contestForDisAmtEmail"
		class="org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean">
		<property name="targetObject" ref="claimsFlowDAO" />
		<property name="targetMethod" value="sendEmailContestForDisAmt" />
