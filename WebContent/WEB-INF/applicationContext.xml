		<property name="repeatInterval" value="300000" />
	</bean>
	<bean class="org.springframework.scheduling.quartz.SchedulerFactoryBean">
		<property name="triggers">
			<list>
				<ref bean="contestForDisAmtEmailTrigger" />
			</list>
		</property>
	</bean> 

